# RustChain Dev Stack - Environment Variables
# Copy to .env and customise as needed:  cp .env.dev.example .env

# ── Node ──────────────────────────────────────────────────────────
NODE_PORT=8099

# ── MongoDB ───────────────────────────────────────────────────────
MONGO_PORT=27017

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Prometheus ────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── Grafana ───────────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=rustchain
