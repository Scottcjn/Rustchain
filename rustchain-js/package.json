{
  "name": "rustchain-js",
  "version": "1.0.0",
  "description": "Official JavaScript SDK for RustChain blockchain",
  "main": "src/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./src/index.cjs"
    }
  },
  "types": "src/index.d.ts",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "build": "echo 'ESM module - no build needed'",
    "docs": "documentation build src/**/*.js -f html -o docs",
    "example": "node examples/basic_usage.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "rustchain",
    "blockchain",
    "rtc",
    "cryptocurrency",
    "sdk",
    "javascript"
  ],
  "author": "RustChain Team <support@rustchain.org>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Scottcjn/rustchain-js.git"
  },
  "bugs": {
    "url": "https://github.com/Scottcjn/rustchain-js/issues"
  },
  "homepage": "https://rustchain.org",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "documentation": "^14.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "node-fetch": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "node-fetch": {
      "optional": true
    }
  }
}
