<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>homebrew.mxcl.bcos-engine</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/opt/bcos-engine/bin/bcos-engine</string>
        <string>--json</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/tmp</string>
    <key>RunAtLoad</key>
    <false/>
    <key>StandardOutPath</key>
    <string>/var/log/bcos-engine.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/bcos-engine-error.log</string>
</dict>
</plist>
