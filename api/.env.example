# RustChain API Server Configuration
# Copy this file to .env and customize for your deployment

# Upstream RustChain node URL
RUSTCHAIN_API_BASE=https://rustchain.org

# Request timeout in seconds
RUSTCHAIN_API_TIMEOUT=10

# Server configuration
PORT=8080
HOST=0.0.0.0

# Debug mode (set to false in production)
FLASK_DEBUG=false

# Rate limiting configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Admin token for protected endpoints (optional but recommended)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=

# SSL/TLS (terminate at reverse proxy in production)
# SSL_CERT_FILE=
# SSL_KEY_FILE=
