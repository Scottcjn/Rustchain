# RustChain Email Notification Service — Configuration
# Copy to .env and fill in your values.

# ─── RustChain API ────────────────────────────────────────────────────────────
RUSTCHAIN_API=https://rustchain.org
RUSTCHAIN_VERIFY_SSL=false

# ─── Polling ──────────────────────────────────────────────────────────────────
POLL_INTERVAL=60
EPOCH_CHECK_INTERVAL=300
OFFLINE_THRESHOLD=600
BALANCE_CHANGE_MIN=0.01

# ─── Daily Digest ─────────────────────────────────────────────────────────────
# Hour (UTC) at which the daily digest is sent (0-23)
DIGEST_HOUR_UTC=8

# ─── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ─── Database ─────────────────────────────────────────────────────────────────
# EMAIL_NOTIFIER_DB=~/.rustchain/email_notifier.db

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
