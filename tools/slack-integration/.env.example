# RustChain Slack Bot Configuration
# Copy to .env and fill in your values.

# Slack credentials (from https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Socket Mode token (optional — enables Socket Mode so no public URL is needed)
# SLACK_APP_TOKEN=xapp-your-app-token

# Channel ID where automated alerts and daily summaries are posted
SLACK_ALERT_CHANNEL=C0123456789

# Comma-separated RustChain node URLs to monitor
RUSTCHAIN_NODE_URLS=https://rustchain.org

# Health-check polling interval in seconds (default: 300 = 5 min)
MONITOR_INTERVAL_SEC=300

# HTTP request timeout in seconds
REQUEST_TIMEOUT_SEC=10

# HTTP server port (used when NOT running in Socket Mode)
PORT=3000
