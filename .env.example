# RustChain Node Configuration
# Copy to .env and customize

# Node
RUSTCHAIN_HOME=/opt/rustchain
RUSTCHAIN_DB=/opt/rustchain/data/rustchain.db
NODE_PORT=8088
DASHBOARD_PORT=8099
LOG_LEVEL=INFO

# Security
ADMIN_KEY=your-admin-key-here
BLOCK_TIME=60

# Wallet
WALLET_NAME=my-miner
WALLET_ADDRESS=RTCxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Network
NODE_URL=https://rustchain.org
SEED_NODES=50.28.86.131:8088

# wRTC Bridge
SOLANA_RPC=https://api.mainnet-beta.solana.com
BASE_RPC=https://mainnet.base.org

# Monitoring (optional)
PROMETHEUS_PORT=9100
GRAFANA_PORT=3000

# Notifications (optional)
SLACK_BOT_TOKEN=
SLACK_ALERT_CHANNEL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=
